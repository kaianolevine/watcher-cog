GOOGLE_CREDENTIALS_JSON=   # Service account credentials JSON as a string (not a file path)
PREFECT_API_KEY=            # Prefect Cloud API key
PREFECT_API_URL=            # Prefect Cloud workspace API URL e.g. https://api.prefect.cloud/api/accounts/{id}/workspaces/{id}
HEALTHCHECKS_URL=           # Healthchecks.io ping URL e.g. https://hc-ping.com/your-uuid
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING

